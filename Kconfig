    menu "Static Libraries"

        config MCUX_COMPONENT_component.sgi_pkc_pqc.static_lib.mcxa5xx
            bool "MCXA5"
			depends on MCUX_HW_DEVICE_MCXA286 || MCUX_HW_DEVICE_MCXA287 || MCUX_HW_DEVICE_MCXA456 || MCUX_HW_DEVICE_MCXA457 || MCUX_HW_DEVICE_MCXA536 || MCUX_HW_DEVICE_MCXA537 || MCUX_HW_DEVICE_MCXA556|| MCUX_HW_DEVICE_MCXA566||  MCUX_HW_DEVICE_MCXA567 || MCUX_HW_DEVICE_MCXA577
		
